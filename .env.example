TELEGRAM_BOT_TOKEN=replace-me
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
BRAVE_API_KEY=replace-me
SYSTEM_PROMPT_PATH=data/system/system_prompt.txt
DATA_DIR=data
CHAT_WINDOW_SIZE=20
MEMORY_REFRESH_EVERY_MESSAGES=10
MEMORY_MIN_WEIGHT=0.15
MEMORY_RETENTION_DAYS=180
BRAVE_SEARCH_RESULTS=8
BRAVE_SCRAPE_RESULTS=3
SITE_CRAWL_MAX_PAGES=8
SITE_CRAWL_CHARS_PER_PAGE=1800
RESEARCH_PARALLEL_SEARCH_WORKERS=8
RESEARCH_PARALLEL_CRAWL_WORKERS=4
SELF_REVIEW_ENABLED=true
RUN_MODE=polling
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_PATH=/telegram/webhook
LOG_LEVEL=INFO
